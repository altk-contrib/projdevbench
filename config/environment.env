# ProjDevBench Environment Configuration Template
# Fill in your actual values below
# IMPORTANT: Never commit sensitive tokens to version control!

# ============================================
# GitHub Configuration
# ============================================
GITHUB_USER="your_github_username"
GITHUB_TOKEN="your_github_token"

# ============================================
# ACMOJ Configuration
# ============================================
ACMOJ_TOKEN="your_acmoj_token"
OJ_API_ENDPOINT="http://localhost:8080/api"

# ============================================
# Gemini API (for gemini-cli)
# ============================================
GEMINI_API_KEY="your_gemini_api_key"
GOOGLE_API_KEY="your_google_api_key"
GOOGLE_GEMINI_BASE_URL=""

# ============================================
# Cursor API
# ============================================
CURSOR_API_KEY="your_cursor_api_key"

# ============================================
# Claude Code API (Anthropic)
# ============================================
ANTHROPIC_BASE_URL="https://api.anthropic.com"
ANTHROPIC_AUTH_TOKEN="your_anthropic_auth_token"
ANTHROPIC_API_KEY="your_anthropic_api_key"

# ============================================
# Augment Code
# ============================================
AUGMENT_SESSION_AUTH='{"accessToken":"your_augment_access_token","tenantURL":"https://your_tenant.api.augmentcode.com/","scopes":["read","write"]}'
# ============================================
# OpenAI / Codex Configuration
# ============================================
OPENAI_API_KEY="your_openai_api_key"
OPENAI_BASE_URL="https://api.openai.com/v1"

# Codex CLI specific (alternative to OPENAI_*)
# Default uses OpenAI official API (https://api.openai.com/v1)
# For OpenRouter: set CODEX_BASE_URL="https://openrouter.ai/api/v1"
CODEX_API_KEY="your_codex_api_key"
CODEX_BASE_URL="https://api.openai.com/v1"  # Default: OpenAI official (https://api.openai.com/v1)

# ============================================
# Proxy Configuration (optional)
# ============================================
# https_proxy=http://host.docker.internal:7890
# http_proxy=http://host.docker.internal:7890
# all_proxy=socks5://host.docker.internal:7890
# no_proxy=localhost,127.0.0.1,host.docker.internal

# ============================================
# Docker Configuration
# ============================================
DOCKER_REGISTRY="ojbench"
AGENT_MEMORY_LIMIT="8g"
AGENT_CPU_LIMIT="4"
